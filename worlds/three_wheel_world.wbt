}

TexturedBackgroundLight {
}

RectangleArena {
  floorSize 3 3
  wallHeight 0.15
}

Robot {
  translation -1.38 -1.38 0.04
  supervisor TRUE
  rotation 0 0 1 0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.6 0.6 0.6
        roughness 0.5
        metalness 0
      }
      geometry Box {
        size 0.20 0.10 0.04
      }
    }

    HingeJoint {
      jointParameters HingeJointParameters {
        anchor 0.04 0.06 -0.01
        axis 0 1 0
      }
      device [
        RotationalMotor {
          name "left wheel motor"
          maxVelocity 20
          maxTorque 100
        }
      ]
      endPoint Solid {
        translation 0.04 0.06 -0.01
        rotation 1 0 0 1.5708
        children [
          Shape {
            appearance PBRAppearance {
              baseColor 0 0 0
              roughness 0.7
              metalness 0
            }
            geometry Cylinder {
              radius 0.03
              height 0.02
              subdivision 36
            }
          }
        ]
        name "left wheel"
        boundingObject Cylinder {
          radius 0.03
          height 0.02
          subdivision 36
        }
        physics Physics {
          density -1
          mass 0.1
        }
      }
    }

    HingeJoint {
      jointParameters HingeJointParameters {
        anchor 0.04 -0.06 -0.01
        axis 0 1 0
      }
      device [
        RotationalMotor {
          name "right wheel motor"
          maxVelocity 20
          maxTorque 100
        }
      ]
      endPoint Solid {
        translation 0.04 -0.06 -0.01
        rotation 1 0 0 1.5708
        children [
          Shape {
            appearance PBRAppearance {
              baseColor 0 0 0
              roughness 0.7
              metalness 0
            }
            geometry Cylinder {
              radius 0.03
              height 0.02
              subdivision 36
            }
          }
        ]
        name "right wheel"
        boundingObject Cylinder {
          radius 0.03
          height 0.02
          subdivision 36
        }
        physics Physics {
          density -1
          mass 0.1
        }
      }
    }

    Solid {
      translation -0.09 0 -0.03
      children [
        Shape {
          appearance PBRAppearance {
            baseColor 0.15 0.15 0.15
            roughness 0.7
            metalness 0
          }
          geometry Sphere {
            radius 0.015
          }
        }
      ]
      name "rear caster"
      boundingObject Sphere {
        radius 0.015
      }
      physics Physics {
        density -1
        mass 0.03
      }
    }
  ]
  name "robot"
  boundingObject Box {
    size 0.20 0.10 0.04
  }
  physics Physics {
    density -1
    mass 1
  }
  controller "move_forward"
}

